# ── MongoDB ────────────────────────────────────────────────────
# Local:
MONGODB_URL=mongodb://localhost:27017
# Atlas (production):
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=propchain_db

# ── AWS (optional — enables real Bedrock AI) ───────────────────
# Option 1: AWS Secrets Manager (recommended for production)
#   Store credentials in Secrets Manager as secret name "keys" in ap-south-1
#   Secret JSON format: {"AWS_ACCESS_KEY_ID": "...", "AWS_SECRET_ACCESS_KEY": "..."}
#   Leave env vars below blank — the app will fetch from Secrets Manager automatically.
#
# Option 2: Direct env vars (local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_REGION=ap-south-1

# ── AWS Bedrock model ──────────────────────────────────────────
BEDROCK_MODEL=apac.anthropic.claude-3-haiku-20240307-v1:0
